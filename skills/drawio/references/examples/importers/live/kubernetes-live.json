{
  "apiVersion": "v1",
  "kind": "List",
  "items": [
    {
      "apiVersion": "apps/v1",
      "kind": "Deployment",
      "metadata": {
        "name": "api",
        "namespace": "shop",
        "annotations": {
          "credential": "annotation-secret-must-not-cross"
        },
        "managedFields": [
          {
            "manager": "private-manager-must-not-cross"
          }
        ]
      },
      "spec": {
        "replicas": 2,
        "template": {
          "metadata": {
            "labels": {
              "app": "api"
            }
          },
          "spec": {
            "containers": [
              {
                "name": "api",
                "env": [
                  {
                    "name": "PASSWORD",
                    "value": "literal-env-secret-must-not-cross"
                  },
                  {
                    "name": "TOKEN",
                    "valueFrom": {
                      "secretKeyRef": {
                        "name": "api-secret",
                        "key": "token"
                      }
                    }
                  }
                ]
              }
            ]
          }
        }
      }
    },
    {
      "apiVersion": "v1",
      "kind": "Secret",
      "metadata": {
        "name": "api-secret",
        "namespace": "shop"
      },
      "data": {
        "token": "a3ViZXJuZXRlcy1zZWNyZXQtbXVzdC1ub3QtY3Jvc3M="
      },
      "stringData": {
        "password": "kubernetes-secret-must-not-cross"
      },
      "binaryData": {
        "certificate": "binary-secret-must-not-cross"
      }
    }
  ]
}
